    "@preowned-cars/db": "workspace:*",
    "@preowned-cars/shared": "workspace:*",
    "ai": "^6.0.159",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.39.0",
    "playwright": "^1.50.0",
    "postgres": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }

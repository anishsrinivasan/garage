{
  "name": "@preowned-cars/scraper",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "scrape": "bun run src/index.ts",
    "scrape:instagram": "bun run src/index.ts --source instagram",

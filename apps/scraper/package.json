    "scrape:olx": "bun run src/index.ts --source olx"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.63",
    "@anthropic-ai/sdk": "^0.39.0",
